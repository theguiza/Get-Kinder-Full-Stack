  <!-- ═══ 5-STEP LOOP ═════════════════════════════ -->
  <section id="loop" class="hiw-section">
    <p class="hiw-eyebrow">End-to-End</p>
    <h2 class="hiw-h2">One loop. Three sides. Every action makes the next one possible.</h2>
    <p class="hiw-lead">
      Each participant gets something real — and gives something real.
      That's not charity. That's a system that sustains itself.
    </p>
    <div class="hiw-steps-grid">
      <div class="hiw-step">
        <p class="hiw-step__num">01</p>
        <span class="hiw-step__icon" aria-hidden="true">
          <svg width="42" height="42" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" style="display:block;">
            <circle cx="100" cy="100" r="90" fill="none" stroke="#ff5656" stroke-width="1" opacity="0.25"/>
            <circle cx="100" cy="100" r="70" fill="none" stroke="#ff5656" stroke-width="1.5" opacity="0.35"/>
            <circle cx="100" cy="100" r="52" fill="none" stroke="#ff5656" stroke-width="2" opacity="0.45"/>
            <circle cx="100" cy="100" r="40" fill="none" stroke="#ff5656" stroke-width="2" opacity="0.55"/>
            <circle cx="100" cy="100" r="28" fill="#ff5656"/>
