  <script>
  (function () {
    var sectionPaths = {
      "/home/assessment": "assessment",
      "/home/how": "how",
      "/home/trust": "trust",
      "/home/faq": "faq",
      "/home/book": "book"
    };
    var initialSection = <% if (typeof scrollToSection !== "undefined" && scrollToSection) { %>"<%= scrollToSection %>"<% } else { %>null<% } %>;

    function scrollToHomeSection(sectionId, behavior) {
      var section = document.getElementById(sectionId);
      if (!section) return;

      var header = document.querySelector(".navbar.fixed-top, .navbar.sticky-top");
      var headerHeight = header ? header.getBoundingClientRect().height : 0;
      var extraOffset = 16;
      var elementPosition = section.getBoundingClientRect().top + window.pageYOffset;
      var top = Math.max(elementPosition - headerHeight - extraOffset, 0);
      window.scrollTo({ top: top, behavior: behavior || "smooth" });
    }

    function sectionFromPath(pathname) {
      return sectionPaths[pathname] || null;
    }

    function handleSectionLinkClick(event) {
      var link = event.target.closest("a[href]");
      if (!link) return;

      var url;
      try {
        url = new URL(link.getAttribute("href"), window.location.origin);
      } catch (e) {
        return;
      }

      if (url.origin !== window.location.origin) return;
      var sectionId = sectionFromPath(url.pathname);
      if (!sectionId) return;

      event.preventDefault();
      window.history.pushState({ sectionId: sectionId }, "", url.pathname + url.search);
      scrollToHomeSection(sectionId, "smooth");
    }

    document.addEventListener("click", handleSectionLinkClick);
    window.addEventListener("popstate", function () {
      var sectionId = sectionFromPath(window.location.pathname);
      if (sectionId) {
        scrollToHomeSection(sectionId, "smooth");
      } else if (window.location.pathname === "/" || window.location.pathname === "/home") {
        window.scrollTo({ top: 0, behavior: "smooth" });
      }
    });

    if (initialSection) {
      var runInitialScroll = function () {
        requestAnimationFrame(function () {
          scrollToHomeSection(initialSection, "smooth");
        });
      };
      if (document.readyState === "complete") {
        runInitialScroll();
      } else {
        window.addEventListener("load", runInitialScroll, { once: true });
      }
    }
  })();
  </script>

