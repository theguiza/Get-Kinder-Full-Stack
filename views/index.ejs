  <!-- Reporting Readiness Modal -->
  <script>
  (function () {
    'use strict';

    var rrStep = 1;
    var rrDirty = false;
    var rrDone = false;
    var rrModal = null;
    var rrSubmitting = false;
    var rrEnteredStep3At = 0;
    var rrSubmitDefaultHtml = 'Submit Application <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';

    /* ── helpers ─────────────────────────────────────── */
    function q(id) { return document.getElementById(id); }
    function v(id) { var el = q(id); return el ? el.value.trim() : ''; }
    function checked(sel) {
      var out = [];
      document.querySelectorAll(sel + ':checked').forEach(function(cb) { out.push(cb.value); });
      return out;
    }
    function styleChkGroup(group) {
      group.querySelectorAll('.rrm-chk-item').forEach(function(item) {
        item.classList.toggle('is-on', !!(item.querySelector('input[type=checkbox]') || {checked:false}).checked);
      });
    }
    function showErr(id) { var e = q(id); if (e) e.classList.add('visible'); }
    function hideErr(id) { var e = q(id); if (e) e.classList.remove('visible'); }
    function markInvalid(id, isInvalid) { var el = q(id); if (el) el.classList.toggle('is-invalid', isInvalid); }
    function resetSubmitButton() {
      rrSubmitting = false;
      var btn = q('rrBtnSubmit');
      if (!btn) return;
      btn.disabled = false;
      btn.innerHTML = rrSubmitDefaultHtml;
    }

    /* ── init ────────────────────────────────────────── */
    function rrInit() {
      var modalEl = q('rrModal');
      if (!modalEl || !window.bootstrap) return;

      rrModal = bootstrap.Modal.getOrCreateInstance(modalEl, { backdrop: 'static', keyboard: false });
      if (modalEl.dataset.rrInitialized === '1') return;
      modalEl.dataset.rrInitialized = '1';

      q('rrCloseBtn').addEventListener('click', rrClose);
      q('rrBtnBack').addEventListener('click', function() { rrGo(rrStep - 1); });
      q('rrBtnNext').addEventListener('click', rrNext);
      q('rrBtnSubmit').addEventListener('click', rrSubmit);
      q('rrBtnCloseFinal').addEventListener('click', function() { rrModal.hide(); rrReset(); });
      q('rrBtnReturn').addEventListener('click', function() {
        rrModal.hide(); rrReset();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      /* Escape key */
      modalEl.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') rrClose();
      });

      /* Focus first field on open */
      modalEl.addEventListener('shown.bs.modal', function() {
        var first = modalEl.querySelector('#rrStep1 input, #rrStep1 select');
        if (first) first.focus();
      });

      /* Conditional: Role Other */
      q('rrRole').addEventListener('change', function() {
        var show = this.value === 'Other';
        q('rrRoleOtherWrap').style.display = show ? 'block' : 'none';
        if (!show) { q('rrRoleOther').value = ''; markInvalid('rrRoleOther', false); hideErr('rrRoleOtherErr'); }
        rrDirty = true;
      });

      /* Conditional: Program area Other */
      q('rrProgramArea').addEventListener('change', function() {
        var show = this.value === 'Other';
        q('rrProgAreaOtherWrap').style.display = show ? 'block' : 'none';
        if (!show) { q('rrProgAreaOther').value = ''; markInvalid('rrProgAreaOther', false); hideErr('rrProgAreaOtherErr'); }
        rrDirty = true;
      });

      /* Checkbox groups */
      q('rrChalGroup').addEventListener('change', function(e) {
        styleChkGroup(this);
        var hasOther = !!this.querySelector('[value=Other]:checked');
        q('rrChalOtherWrap').style.display = hasOther ? 'block' : 'none';
        if (!hasOther) { q('rrChalOther').value = ''; markInvalid('rrChalOther', false); hideErr('rrChalOtherErr'); }
        if (checked('#rrChalGroup input[type=checkbox]').length) hideErr('rrChalErr');
        rrDirty = true;
      });

      q('rrDataLocGroup').addEventListener('change', function() {
        styleChkGroup(this);
        var hasOther = !!this.querySelector('[value=Other]:checked');
        q('rrDataLocOtherWrap').style.display = hasOther ? 'block' : 'none';
        if (!hasOther) { q('rrDataLocOther').value = ''; markInvalid('rrDataLocOther', false); hideErr('rrDataLocOtherErr'); }
        if (checked('#rrDataLocGroup input[type=checkbox]').length) hideErr('rrDataLocErr');
        rrDirty = true;
      });

      q('rrShareGroup').addEventListener('change', function() {
        styleChkGroup(this);
        if (checked('#rrShareGroup input[type=checkbox]').length) hideErr('rrShareErr');
        rrDirty = true;
      });

      /* Scale buttons */
      document.querySelectorAll('.rrm-scale-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('.rrm-scale-btn').forEach(function(b) {
            b.classList.remove('is-on'); b.setAttribute('aria-pressed', 'false');
          });
          this.classList.add('is-on'); this.setAttribute('aria-pressed', 'true');
          q('rrConf').value = this.dataset.val;
          hideErr('rrConfErr');
          rrDirty = true;
        });
      });

      /* Consent */
      q('rrConsent').addEventListener('change', function() {
        q('rrConsentWrap').classList.toggle('is-invalid', !this.checked);
        if (this.checked) hideErr('rrConsentErr');
        rrDirty = true;
      });

      /* Mark dirty on any input */
      modalEl.querySelectorAll('input, select, textarea').forEach(function(el) {
        el.addEventListener('input', function() { rrDirty = true; });
      });
    }

    /* ── close with guard ────────────────────────────── */
    function rrClose() {
      if (rrDirty && !rrDone) {
        if (!confirm('You have started filling out the application. Close and lose your progress?')) return;
      }
      rrModal.hide();
      setTimeout(rrReset, 350);
    }

    /* ── reset ───────────────────────────────────────── */
    function rrReset() {
      rrStep = 1; rrDirty = false; rrDone = false; rrEnteredStep3At = 0;
      var modalEl = q('rrModal');
      if (!modalEl) return;
      modalEl.querySelectorAll('input, select, textarea').forEach(function(el) {
        if (el.type === 'checkbox') el.checked = false;
        else el.value = '';
      });
      document.querySelectorAll('.rrm-scale-btn').forEach(function(b) {
        b.classList.remove('is-on'); b.setAttribute('aria-pressed', 'false');
      });
      document.querySelectorAll('.rrm-chk-item').forEach(function(i) { i.classList.remove('is-on'); });
      document.querySelectorAll('.rrm-err').forEach(function(e) { e.classList.remove('visible'); });
      document.querySelectorAll('.rrm-input,.rrm-select,.rrm-textarea').forEach(function(e) { e.classList.remove('is-invalid'); });
      var cw = q('rrConsentWrap'); if (cw) cw.classList.remove('is-invalid');
      ['rrRoleOtherWrap','rrProgAreaOtherWrap','rrChalOtherWrap','rrDataLocOtherWrap'].forEach(function(id) {
        var el = q(id); if (el) el.style.display = 'none';
      });
      var se = q('rrStep3') && q('rrStep3').querySelector('.rrm-submit-error');
      if (se) se.remove();
      resetSubmitButton();
      rrGo(1, true);
    }

    /* ── navigate steps ──────────────────────────────── */
    function rrGo(step, silent) {
      ['rrStep1','rrStep2','rrStep3','rrConfirm'].forEach(function(id) {
        var el = q(id); if (el) el.style.display = 'none';
      });
      [1,2,3].forEach(function(n) {
        var ps = q('rrProg' + n);
        if (!ps) return;
        ps.classList.remove('is-active','is-done');
        if (step > 3) ps.classList.add('is-done');
        else if (n < step) ps.classList.add('is-done');
        else if (n === step) ps.classList.add('is-active');
      });
      if (step <= 3) { var panel = q('rrStep' + step); if (panel) panel.style.display = 'block'; }
      else { var c = q('rrConfirm'); if (c) c.style.display = 'block'; }

      var back = q('rrBtnBack'), next = q('rrBtnNext'), sub = q('rrBtnSubmit');
      var ret = q('rrBtnReturn'), cls = q('rrBtnCloseFinal');
      back.style.display  = (step > 1 && step <= 3) ? 'inline-flex' : 'none';
      next.style.display  = (step <= 2) ? 'inline-flex' : 'none';
      sub.style.display   = (step === 3) ? 'inline-flex' : 'none';
      ret.style.display   = (step > 3) ? 'inline-flex' : 'none';
      cls.style.display   = (step > 3) ? 'inline-flex' : 'none';
      if (step === 3 && !rrSubmitting) {
        rrEnteredStep3At = Date.now();
        resetSubmitButton();
      }

      if (step === 1) next.innerHTML = 'Next: Reporting needs <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';
      if (step === 2) next.innerHTML = 'Next: Data readiness <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';

      rrStep = step;
      var body = document.querySelector('#rrModal .modal-body');
      if (body) body.scrollTop = 0;

      if (!silent) {
        setTimeout(function() {
          var panel = (step <= 3 ? q('rrStep' + step) : q('rrConfirm'));
          if (panel) { var f = panel.querySelector('input,select,textarea,button'); if (f) f.focus(); }
        }, 60);
      }
    }

    /* ── validate ────────────────────────────────────── */
    function vReq(fid, eid) {
      var el = q(fid), ok = el && el.value.trim().length > 0;
      markInvalid(fid, !ok);
      ok ? hideErr(eid) : showErr(eid);
      if (ok && el) el.addEventListener('input', function() { markInvalid(fid, false); hideErr(eid); }, { once: true });
      return ok;
    }
    function vEmail(fid, eid) {
      var el = q(fid), ok = el && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value.trim());
      markInvalid(fid, !ok); ok ? hideErr(eid) : showErr(eid);
      if (ok && el) el.addEventListener('input', function() { markInvalid(fid, false); hideErr(eid); }, { once: true });
      return ok;
    }
    function vUrl(fid, eid) {
      var el = q(fid);
      if (!el) return false;
      var val = el.value.trim();
      if (!val) { markInvalid(fid, true); showErr(eid); return false; }
      if (!/^https?:\/\//i.test(val)) { el.value = 'https://' + val; val = el.value; }
      var ok = /^https?:\/\/.+\..+/.test(val);
      markInvalid(fid, !ok); ok ? hideErr(eid) : showErr(eid);
      if (ok) el.addEventListener('input', function() { markInvalid(fid, false); hideErr(eid); }, { once: true });
      return ok;
    }
    function vChk(sel, eid) {
      var ok = checked(sel).length > 0;
      ok ? hideErr(eid) : showErr(eid);
      return ok;
    }
    function vHidden(fid, eid) {
      var el = q(fid), ok = el && el.value.length > 0;
      ok ? hideErr(eid) : showErr(eid);
      return ok;
    }

    function rrValidate(step) {
      var ok = true;
      if (step === 1) {
        ok = vReq('rrOrgName','rrOrgNameErr') & ok;
        ok = vUrl('rrWebsite','rrWebsiteErr') & ok;
        ok = vReq('rrContactName','rrContactNameErr') & ok;
        ok = vReq('rrRole','rrRoleErr') & ok;
        if (v('rrRole') === 'Other') ok = vReq('rrRoleOther','rrRoleOtherErr') & ok;
        ok = vEmail('rrEmail','rrEmailErr') & ok;
        ok = vReq('rrBudget','rrBudgetErr') & ok;
        ok = vReq('rrProgramArea','rrProgramAreaErr') & ok;
        if (v('rrProgramArea') === 'Other') ok = vReq('rrProgAreaOther','rrProgAreaOtherErr') & ok;
      }
      if (step === 2) {
        ok = vReq('rrFundingStatus','rrFundingStatusErr') & ok;
        ok = vChk('#rrChalGroup input[type=checkbox]','rrChalErr') & ok;
        if (!!q('rrChalGroup').querySelector('[value=Other]:checked')) ok = vReq('rrChalOther','rrChalOtherErr') & ok;
        ok = vReq('rrDeadline','rrDeadlineErr') & ok;
        ok = vHidden('rrConf','rrConfErr') & ok;
        ok = vReq('rrFunderUnderstanding','rrFunderUnderstandingErr') & ok;
      }
      if (step === 3) {
        ok = vChk('#rrDataLocGroup input[type=checkbox]','rrDataLocErr') & ok;
        if (!!q('rrDataLocGroup').querySelector('[value=Other]:checked')) ok = vReq('rrDataLocOther','rrDataLocOtherErr') & ok;
        ok = vChk('#rrShareGroup input[type=checkbox]','rrShareErr') & ok;
        ok = vReq('rrSensitive','rrSensitiveErr') & ok;
        ok = vReq('rrAnonLearnings','rrAnonLearningsErr') & ok;
        ok = vReq('rrAssessValue','rrAssessValueErr') & ok;
        var consent = q('rrConsent').checked;
        q('rrConsentWrap').classList.toggle('is-invalid', !consent);
        consent ? hideErr('rrConsentErr') : showErr('rrConsentErr');
        ok = consent & ok;
      }
      if (!ok) {
        setTimeout(function() {
          var first = document.querySelector('#rrModal .rrm-err.visible');
          if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 40);
      }
      return !!ok;
    }

    /* ── next ────────────────────────────────────────── */
    function rrNext() { if (rrValidate(rrStep)) rrGo(rrStep + 1); }

    /* ── submit ──────────────────────────────────────── */
    async function rrSubmit() {
      if (rrSubmitting) return;
      if (rrEnteredStep3At && Date.now() - rrEnteredStep3At < 600) return;
      if (!rrValidate(3)) return;
      var btn = q('rrBtnSubmit');
      rrSubmitting = true;
      btn.disabled = true;
      btn.innerHTML = 'Submitting…';

      var data = {
        org_name: v('rrOrgName'), website: v('rrWebsite'),
        contact_name: v('rrContactName'), role: v('rrRole'), role_other: v('rrRoleOther'),
        email: v('rrEmail'), phone: v('rrPhone'),
        budget_range: v('rrBudget'), program_area: v('rrProgramArea'), program_area_other: v('rrProgAreaOther'),
        funding_status: v('rrFundingStatus'), funders_list: v('rrFundersList'),
        reporting_challenges: checked('#rrChalGroup input[type=checkbox]'),
        reporting_challenge_other: v('rrChalOther'),
        upcoming_deadline: v('rrDeadline'),
        confidence_rating: parseInt(v('rrConf'), 10) || null,
        funder_understanding: v('rrFunderUnderstanding'),
        data_locations: checked('#rrDataLocGroup input[type=checkbox]'),
        data_locations_other: v('rrDataLocOther'),
        shareable_materials: checked('#rrShareGroup input[type=checkbox]'),
        sensitive_data: v('rrSensitive'), anonymized_learnings: v('rrAnonLearnings'),
        assessment_value: v('rrAssessValue'), additional_notes: v('rrNotes'),
        consent: q('rrConsent').checked
      };

      try {
        var res = await fetch('/api/reporting-readiness/apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        var json = await res.json().catch(function() { return {}; });
        if (!res.ok) throw new Error(json.message || 'Submission failed. Please try again.');
        rrDone = true;
        window.location.assign('/assessment-received');
      } catch (err) {
        resetSubmitButton();
        var prev = q('rrStep3').querySelector('.rrm-submit-error');
        if (prev) prev.remove();
        var errDiv = document.createElement('div');
        errDiv.className = 'rrm-submit-error';
        errDiv.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> ' + err.message;
        q('rrStep3').insertBefore(errDiv, q('rrStep3').firstChild);
        q('rrModal').querySelector('.modal-body').scrollTop = 0;
      }
    }

    /* ── public open function ────────────────────────── */
    window.openReportingReadinessModal = function () {
      if (!rrModal) rrInit();
      if (!rrDirty || rrDone) rrReset();
      if (rrModal) rrModal.show();
    };

    document.addEventListener('DOMContentLoaded', rrInit);
  })();
  </script>

