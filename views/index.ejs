              <div style="background:#fafafa;border:1px dashed #c4c6cc;border-radius:8px;padding:12px;display:flex;align-items:center;gap:10px;transform:rotate(0.3deg);"><i data-lucide="mail" style="width:15px;height:15px;color:#6e7280;flex-shrink:0;"></i><span style="font-family:'Roboto',sans-serif;font-size:13px;color:#4d525e;">Emails</span></div>
