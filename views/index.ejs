  <section id="trust" style="background:#283853;padding:112px 0;">
    <div class="container" style="max-width:1200px;">
      <div class="row g-5 align-items-start">
        <!-- Left -->
        <div class="col-12 col-lg-5">
          <div class="gk-eyebrow gk-eyebrow-dark">Data handling &amp; trust</div>
          <h2 style="font-family:'Poppins',sans-serif;font-weight:600;font-size:clamp(26px,3vw,38px);letter-spacing:-0.02em;color:#fff;margin:0;line-height:1.15;">
            Your data stays yours.
            <span style="font-family:'Lora',serif;font-style:italic;font-weight:500;color:#ffbbbb;"> Your trust comes first.</span>
          </h2>
          <p style="margin-top:22px;font-family:'Roboto',sans-serif;font-size:16px;color:#dfe3ec;line-height:1.65;max-width:460px;">
            Nonprofits often hold sensitive program, participant, volunteer, donor, and community information. The assessment is designed to minimize risk from the start.
          </p>
          <div style="margin-top:28px;">
            <a href="/home/book" class="gk-cta-primary">Book a Reporting Readiness Call <i data-lucide="arrow-right" style="width:15px;height:15px;"></i></a>
