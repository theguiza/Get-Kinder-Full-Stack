  <style>
    /* ── Impact Reporting Homepage ─────────────────────── */
    [data-lucide] { display: inline-flex; vertical-align: middle; flex-shrink: 0; }
    .gk-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'Roboto', sans-serif; font-size: 11px; letter-spacing: 0.12em;
      text-transform: uppercase; color: #FF5656; font-weight: 600; margin-bottom: 14px;
    }
    .gk-eyebrow::before { content: ''; display: inline-block; width: 18px; height: 1px; background: #FF5656; opacity: 0.8; }
    .gk-eyebrow-dark { color: #ff8c83; }
    .gk-eyebrow-dark::before { background: #ff8c83; }
    .gk-section { padding: 112px 0; }
    .gk-section-sm { padding: 80px 0; }
    .gk-cta-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: #FF5656; color: #fff !important; border-radius: 10px; padding: 13px 22px;
      font-family: 'Roboto', sans-serif; font-size: 15px; font-weight: 500;
      text-decoration: none; white-space: nowrap;
      box-shadow: 0 1px 2px rgba(31,38,48,.06), 0 2px 6px rgba(255,86,86,.18);
      transition: transform 160ms ease, box-shadow 160ms ease;
    }
    .gk-cta-primary:hover { transform: translateY(-1px); box-shadow: 0 2px 4px rgba(31,38,48,.06), 0 8px 18px rgba(255,86,86,.24); }
    .gk-cta-primary-lg { padding: 15px 24px; font-size: 16px; }
    .gk-cta-secondary {
      display: inline-flex; align-items: center; gap: 6px;
      background: #fff; color: #283853 !important; border: 1px solid #dcdde0;
      border-radius: 10px; padding: 13px 22px;
      font-family: 'Roboto', sans-serif; font-size: 15px; font-weight: 500;
      text-decoration: none; white-space: nowrap; transition: background 160ms;
    }
    .gk-cta-secondary:hover { background: #fafafa; }
    .gk-sh-title {
      font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 38px;
      letter-spacing: -0.02em; color: #283853; margin: 0; line-height: 1.15;
    }
    .gk-sh-body { margin-top: 18px; font-family: 'Roboto', sans-serif; font-size: 17px; color: #4d525e; line-height: 1.6; }
    .gk-card { background: #fff; border: 1px solid #e3e4e8; border-radius: 14px; padding: 28px; }
    .gk-hero-nav-link {
      font-family: 'Roboto', sans-serif; font-size: 14px; color: #455A7C;
      text-decoration: none; font-weight: 500; transition: color 140ms;
    }
    .gk-hero-nav-link:hover { color: #FF5656; }
    .gk-faq-btn {
      background: transparent; border: none; width: 100%; text-align: left; cursor: pointer;
      padding: 22px 4px; display: flex; align-items: center; justify-content: space-between; gap: 16px;
      font-family: 'Poppins', sans-serif; font-weight: 500; font-size: 17px; color: #283853;
    }
    .gk-faq-icon {
      width: 28px; height: 28px; border-radius: 999px; display: flex;
      align-items: center; justify-content: center; transition: background 160ms; flex-shrink: 0;
    }
    .gk-faq-body {
      overflow: hidden; transition: max-height 280ms cubic-bezier(0.2,0.7,0.2,1);
      font-family: 'Roboto', sans-serif; font-size: 15px; color: #4d525e; line-height: 1.65;
    }
    .gk-faq-body-inner { padding: 0 4px 22px 46px; }
    .gk-del-grid { display: grid; grid-template-columns: repeat(6,1fr); gap: 20px; }
    .gk-del-sm { grid-column: span 2; }
    .gk-del-lg { grid-column: span 3; }
    @media (max-width: 991px) {
      .gk-section { padding: 72px 0; } .gk-sh-title { font-size: 30px; }
      .gk-del-sm, .gk-del-lg { grid-column: span 3; }
    }
    @media (max-width: 767px) {
      .gk-section { padding: 56px 0; } .gk-sh-title { font-size: 26px; }
      .gk-del-sm, .gk-del-lg { grid-column: span 6; }
    }
  </style>
