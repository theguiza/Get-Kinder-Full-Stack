  <div class="modal fade" id="rrModal" tabindex="-1" role="dialog"
       aria-labelledby="rrModalTitle" aria-modal="true" aria-describedby="rrModalDesc">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">

        <!-- HEADER -->
        <div class="modal-header rrm-header">
          <div class="rrm-header-top">
            <div style="flex:1;min-width:0;">
              <div class="gk-eyebrow" style="margin-bottom:8px;">Design partner application</div>
              <h2 class="rrm-title" id="rrModalTitle">Apply for a Reporting Readiness Call</h2>
              <p class="rrm-intro" id="rrModalDesc">We're selecting 5 nonprofit design partners for a free Impact Reporting &amp; Data Readiness Assessment. Answer a few questions so we can understand your reporting needs and confirm whether the assessment is a strong fit.</p>
