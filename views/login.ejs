  <meta name="author" content="Get Kindr Foundation">
  <meta name="robots" content="index, follow">

  <meta property="og:title" content="Get Kinder | The 5-Minute AI Mattering Hack for Happiness & Connection">
  <meta property="og:description" content="Discover Get Kinder, your AI-powered mattering companion. Build deeper connections, spread joy, and improve wellbeing with daily 5-minute acts of mattering.">
  <meta property="og:url" content="https://getkinder.ai/">
  <meta property="og:type" content="website">

  <link rel="icon" href="/images/favicon.png" sizes="32x32" type="image/png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous">
  <link rel="stylesheet" href="./css/style.css">
  <style>
    .login-feedback-overlay {
      position: fixed;
      inset: 0;
      z-index: 2000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      pointer-events: none;
    }

    .login-feedback-stack {
      width: min(680px, 100%);
      display: grid;
      gap: 0.75rem;
    }

    .login-feedback-stack .alert {
      margin: 0;
      pointer-events: auto;
      box-shadow: 0 12px 32px rgba(20, 36, 64, 0.2);
    }

  </style>
</head>

<body class="profile-body">
  <% if ((typeof error !== "undefined" && error) || (typeof success !== "undefined" && success)) { %>
    <div class="login-feedback-overlay" aria-live="polite">
      <div class="login-feedback-stack">
        <% if (typeof error !== "undefined" && error) { %>
          <div class="alert alert-danger alert-dismissible fade show auto-dismiss" role="alert">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
        <% if (typeof success !== "undefined" && success) { %>
          <div class="alert alert-success alert-dismissible fade show auto-dismiss" role="alert">
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>
  <section id="title"> 
    <body class="gradient-background">  
<%- include("partials/site-header", { currentPage: "other" }) %>
   <div class="container mt-5 pt-5 login-signin-offset">
      <div class="row align-items-center">
    <!-- Login Form Left -->
    <div class="col-lg-6">
      					<div class="login_wrapper">
                  		<div class="container">
							<div class="row">
							<!-- login_wrapper <div class="col-lg-6 col-md-6 col-xs-12 col-sm-6">
									<a href="#" class="btn btn-primary btn-lgr"> <span>Login with Facebook</span> <i class="fa fa-facebook"></i> </a>
								</div> -->	
                <div class="col-12">
                  <div class="d-flex justify-content-center ">
                    <a href="/auth/google" class="btn btn-primary google-plus w-100">
                      <img src="./images/google.png" alt="Google logo"><span class="d-inline d-sm-none" style="color: #000;">Sign in</span>
    <span class="d-none d-sm-inline" style="color: #000;">Sign in with Google</span>
                    </a>
                  </div>
                </div>
                </div>
							</div>
        <h2>or</h2>
        <form id="login-form" action="/login" method="POST" autocomplete="off">
          <div class="form-group">
            <input type="email" name="email" class="form-control" required placeholder="Email Address *" autocomplete="off" autocapitalize="none" spellcheck="false">
          </div>
          <div class="form-group mt-3">
            <input type="password" name="password" class="form-control" required placeholder="Password *" autocomplete="new-password">
          </div>
          <div class="login_remember_box mt-3 d-flex justify-content-end">
            <a href="/forgot-password" class="forget_password">Forgot Password</a>
          </div>
          <div class="login_btn_wrapper mt-4">
            <button type="submit" class="btn btn-primary w-100">Login</button>
          </div>
          <div class="login_message">
								<p>Don't have an account? <a href="register"> Create account </a> </p>
							</div>
        </form>
      </div>
    </div>

    <!-- Image Right -->
    <div class="col-lg-6 text-center">
      <img src="./images/kai-real.png" class="img-fluid" alt="KAI the AI coach" height="100px; width: auto;" loading="lazy">
    </div>
  </div>
</div>
  <!-- Footer section needs a logo to the far left -->
  <section id="contact">
    <div class="container">
      <footer class="row row-cols-1 row-cols-sm-2 row-cols-md-5 py-5 mt-5 border-top">
        <div class="col mb-3">
          <div class="col mb-3">
                 <a href="#">
                  <img src="./images/heart3D.png" alt="Get Kinder Heart" height="150">
                 </a>
              </div>
            <p class="text-body-secondary" style="color: #455a7c;">© Get Kindr Foundation </p>
        </div>
        <div class="col mb-3">
        </div>
  </section>
  <script>
  (function () {
    function clearLoginForm() {
      const form = document.getElementById("login-form");
      if (!form) return;
      form.reset();
      const emailInput = form.querySelector('input[name="email"]');
      const passwordInput = form.querySelector('input[name="password"]');
      if (emailInput) emailInput.value = "";
      if (passwordInput) passwordInput.value = "";
    }

    document.addEventListener("DOMContentLoaded", clearLoginForm);
    window.addEventListener("pageshow", clearLoginForm);
    window.addEventListener("load", function () {
      setTimeout(clearLoginForm, 60);
    });
  })();
</script>
  <script>
  (function () {
    function maybeRemoveOverlay(overlay) {
      if (!overlay) return;
      if (overlay.querySelectorAll(".alert").length === 0) {
        overlay.remove();
      }
    }

    function closeAlert(alertEl) {
      if (!alertEl || !alertEl.isConnected) return;
      if (window.bootstrap?.Alert) {
        window.bootstrap.Alert.getOrCreateInstance(alertEl).close();
        return;
      }
      alertEl.classList.remove("show");
      setTimeout(function () {
        alertEl.remove();
      }, 180);
    }

    window.addEventListener("DOMContentLoaded", function () {
      const overlay = document.querySelector(".login-feedback-overlay");
      if (!overlay) return;

      const alerts = overlay.querySelectorAll(".alert.auto-dismiss");
      alerts.forEach(function (alertEl) {
        alertEl.addEventListener("closed.bs.alert", function () {
          maybeRemoveOverlay(overlay);
        });
        setTimeout(function () {
          closeAlert(alertEl);
          setTimeout(function () {
            maybeRemoveOverlay(overlay);
          }, 220);
        }, 7000);
      });
    });
  })();
  </script>
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script> 
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>

</html>
