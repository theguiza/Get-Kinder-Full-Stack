<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<!-- Google Tag Manager -->  
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-5NMWPW33');</script>
  <%#End Google Tag Manager %>
  <title>Get Kinder | Organization Portal - Manage Volunteer Opportunities & Verified Impact</title>
  <meta name="author" content="Get Kindr Foundation">
  <meta name="description" content="Use the Get Kinder Organization Portal to manage volunteer opportunities, track RSVPs, verify attendance, and connect community impact to transparent donor-backed funding.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="canonical" href="https://getkinder.ai/org-portal">
  <meta property="og:title" content="Get Kinder | Organization Portal - Manage Volunteer Opportunities & Verified Impact">
  <meta property="og:description" content="Manage volunteer opportunities, track RSVPs, verify attendance, and connect community impact to transparent donor-backed funding through Get Kinder.">
  <meta property="og:url" content="https://getkinder.ai/org-portal">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://getkinder.ai/images/logo.png">
  <meta property="og:locale" content="en_CA">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Get Kinder Organization Portal | Manage Volunteer Opportunities">
  <meta name="twitter:description" content="Manage volunteer opportunities, track RSVPs, verify attendance, and connect community impact to transparent funding.">
  <meta name="twitter:image" content="https://getkinder.ai/images/logo.png">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <link rel="icon" href="/images/favicon.png" sizes="32x32" type="image/png">
  <!-- Bootstrap CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous">
  <!-- Font Awesome CDN -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Shared styles -->
  <link rel="stylesheet" href="/css/style.css">
  <!-- Page styles -->
  <link rel="stylesheet" href="/css/org-portal.css?<%= assetTag %>">
  <link rel="stylesheet" href="/css/gk-design-tokens.css?<%= assetTag %>" />
</head>
<body class="org-portal-page">
<!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5NMWPW33"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <%- include("partials/site-header", { currentPage: "org-portal" }) %>

  <div class="org-portal-nav-spacer" aria-hidden="true"></div>

  <%
    const activeOrgStatusValue = String(activeOrgStatus || "").trim().toLowerCase();
    const orgIsSuspended = activeOrgStatusValue === "suspended";
  %>

  <main class="org-portal-main container <%= orgIsSuspended ? 'org-portal-content-ghosted' : '' %>">
    <%
      const fullName = `${user?.firstname || ""} ${user?.lastname || ""}`.trim() || user?.name || "Organization Lead";
      const resolvedOrganizationName =
        (typeof organizationName === "string" && organizationName.trim())
        || user?.organization_name
        || user?.organization
        || user?.org_name
        || "Get Kinder";
      const orgLogoUrl =
        (typeof organizationLogoUrl === "string" && organizationLogoUrl.trim())
        || "/images/favicon.png";
      const safeLogoUploadError = (typeof logoUploadError !== "undefined" && logoUploadError) ? logoUploadError : "";
      const safeDescription = (typeof organizationDescription === "string" && organizationDescription) ? organizationDescription : "";
      const safeDescriptionError = (typeof descriptionError !== "undefined" && descriptionError) ? descriptionError : "";
      const showDescriptionSaved = descriptionSaved === true;
      const orgRatingData = (typeof orgRating !== "undefined" && orgRating) ? orgRating : {};
      const orgRatingCount = Number(orgRatingData.count) || 0;
      const orgRatingValue = Number.isFinite(Number(orgRatingData.value))
        ? Number(orgRatingData.value)
        : 5;
      const orgRatingPercent = Math.max(0, Math.min(100, (orgRatingValue / 5) * 100));
      const normalizedActiveOrgId = Number.isInteger(Number(activeOrgId)) ? Number(activeOrgId) : null;
      const membershipOptions = Array.isArray(orgMemberships)
        ? orgMemberships
            .map((entry) => ({
              orgId: Number(entry?.orgId),
              name: String(entry?.name || "").trim(),
            }))
            .filter((entry) => Number.isInteger(entry.orgId) && entry.orgId > 0)
        : [];
      const canSwitchOrganizations = membershipOptions.length > 1;
    %>
    <section class="org-hero mb-3" aria-label="Organization profile hero">
      <div class="org-hero-card">
        <div class="row g-4 align-items-center">
          <div class="col-12 col-md-3 text-center org-hero-logo-col">
            <img
              id="org-hero-logo"
              class="org-hero-avatar rounded-circle"
              width="140"
              height="140"
              alt="Logo for <%= resolvedOrganizationName %>"
              src="<%= orgLogoUrl %>">
            <% if (!orgIsSuspended) { %>
              <button
                type="button"
                class="btn btn-sm btn-outline-secondary org-logo-trigger"
                data-bs-toggle="modal"
                data-bs-target="#orgLogoModal"
                aria-label="Set organization logo">
                Save Your Logo
              </button>
            <% } %>
          </div>
          <div class="col-12 col-md-5 text-center text-md-start org-hero-summary-col">
            <div class="org-hero-org"><%= resolvedOrganizationName %></div>
            <h1 class="org-hero-name"><%= fullName %></h1>
            <div class="org-hero-rating-stack">
              <div
                class="org-hero-rating"
                role="img"
                aria-label="Organization rating <%= orgRatingValue.toFixed(1) %> out of 5 stars from <%= orgRatingCount %> ratings"
              >
                <span class="org-hero-rating-stars" aria-hidden="true">
                  <span class="org-hero-rating-stars-base">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                  <span
                    class="org-hero-rating-stars-fill"
                    data-rating-width="<%= orgRatingPercent.toFixed(1) %>"
                  >&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                </span>
                <span class="org-hero-rating-text">
                  <%= `${orgRatingValue.toFixed(1)} (${orgRatingCount})` %>
                </span>
              </div>
              <div class="org-admin-cta-wrap">
                <button type="button" id="org-request-admin-btn" class="btn btn-sm org-btn-ink">
                  Add Admin
                </button>
              </div>
              <% if (!orgIsSuspended) { %>
                <form method="POST" action="/org-portal/description" class="org-description-form">
                  <label for="org-description-input" class="org-description-label">Organization Description</label>
                  <% if (showDescriptionSaved) { %>
                    <div class="alert alert-success org-description-alert" role="status">
                      Organization description saved.
                    </div>
                  <% } %>
                  <% if (safeDescriptionError === "tooLong") { %>
                    <div class="alert alert-danger org-description-alert" role="alert">
                      Keep the description under 2000 characters.
                    </div>
                  <% } else if (safeDescriptionError === "saveFailed") { %>
                    <div class="alert alert-danger org-description-alert" role="alert">
                      We couldn't save the description. Please try again.
                    </div>
                  <% } else if (safeDescriptionError === "forbidden") { %>
                    <div class="alert alert-danger org-description-alert" role="alert">
                      Only organization admins can update the description.
                    </div>
                  <% } %>
                  <textarea
                    id="org-description-input"
                    name="orgDescription"
                    class="form-control org-description-input"
                    rows="4"
                    maxlength="2000"
                    placeholder="Add a short description of your organization."><%= safeDescription %></textarea>
                  <div class="org-description-actions">
                    <button type="submit" class="btn btn-sm org-description-save-btn">Save description</button>
                  </div>
                </form>
              <% } else if (safeDescription) { %>
                <div class="org-description-static"><%= safeDescription %></div>
              <% } %>
            </div>
            <% if (canSwitchOrganizations) { %>
              <div class="mt-3">
                <label for="org-active-switch" class="form-label mb-1 fw-semibold small text-uppercase text-muted">
                  Active Organization
                </label>
                <select id="org-active-switch" class="form-select form-select-sm">
                  <% membershipOptions.forEach((option) => { %>
                    <option
                      value="<%= option.orgId %>"
                      <%= option.orgId === normalizedActiveOrgId ? "selected" : "" %>
                    >
                      <%= option.name || `Organization #${option.orgId}` %>
                    </option>
                  <% }) %>
                </select>
              </div>
            <% } %>
          </div>
          <div class="col-12 col-md-4 org-hero-kpi-col">
            <div id="org-portal-kpis"></div>
          </div>
        </div>
      </div>
    </section>

    <% if (!orgIsSuspended) { %>
      <form id="org-logo-form" action="/org-portal/logo" method="POST" enctype="multipart/form-data">
        <div class="modal fade" id="orgLogoModal" tabindex="-1" aria-labelledby="orgLogoModalLabel" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <div class="org-logo-title-wrap">
                  <img src="/images/favicon.png" alt="Get Kinder logo" class="org-logo-modal-mark" loading="lazy">
                  <h5 class="modal-title" id="orgLogoModalLabel">Set your organization logo</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <% if (safeLogoUploadError === 'fileTooLarge') { %>
                  <div class="alert alert-danger mb-3" role="alert">
                    Sorry, that image is too big. Please choose one under 2 MB.
                  </div>
                <% } else if (safeLogoUploadError === 'noFileSelected') { %>
                  <div class="alert alert-danger mb-3" role="alert">
                    Choose a logo before saving.
                  </div>
                <% } else if (safeLogoUploadError === 'uploadFailed') { %>
                  <div class="alert alert-danger mb-3" role="alert">
                    Sorry, we couldn't upload that logo. Please try again.
                  </div>
                <% } %>
                <div id="org-logo-client-error" class="alert alert-danger mb-3 d-none" role="alert"></div>
                <p class="mb-2">Set your organization logo</p>
                <input
                  id="org-logo-input"
                  type="file"
                  name="logo"
                  accept="image/*"
                  class="form-control"
                  aria-label="Upload your organization logo">
                <small class="text-muted d-block mt-2">Upload a new logo (max 2 MB)</small>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn org-logo-save-btn" name="org_action" value="save_logo">Save logo</button>
              </div>
            </div>
          </div>
        </div>
      </form>
    <% } %>

    <section class="org-split-shell mb-4" aria-label="Organization workspace">
      <div id="org-portal-root"></div>
    </section>
  </main>

  <% if (orgIsSuspended) { %>
    <div class="org-suspended-overlay" role="dialog" aria-modal="true" aria-labelledby="org-suspended-title">
      <div class="org-suspended-dialog">
        <h2 id="org-suspended-title">Organization Access Suspended</h2>
        <p class="mb-0">
          You have been suspended please send a message to
          <a href="mailto:kai@getkinder.ai">kai@getkinder.ai</a>
          to request being unsuspended.
        </p>
      </div>
    </div>
  <% } %>

  <div
    id="org-admin-request-modal"
    class="org-admin-request-backdrop"
    role="dialog"
    aria-modal="true"
    aria-labelledby="org-admin-request-title"
    style="display:none;"
  >
    <div class="org-admin-request-card shadow">
      <div class="org-admin-request-header">
        <div class="org-admin-request-title-wrap">
          <span class="org-admin-request-mark" aria-hidden="true">k</span>
          <h5 id="org-admin-request-title" class="mb-0">Add Admin</h5>
        </div>
        <button type="button" id="org-admin-request-close-x" class="org-admin-request-close-x" aria-label="Close">
          &times;
        </button>
      </div>
      <div class="org-admin-request-body">
        To request another admin for your organization send a request to
        <a href="mailto:kai@getkinder.ai">kai@getkinder.ai</a>
      </div>
      <div class="org-admin-request-footer">
        <button type="button" id="org-admin-request-close" class="btn btn-sm org-admin-request-close-btn">
          Close
        </button>
      </div>
    </div>
  </div>

  <section id="footer" class="gradient-background <%= orgIsSuspended ? 'org-portal-content-ghosted' : '' %>">
  <div class="container">
    <footer class="row align-items-center py-5 mt-5 border-top text-body-secondary">
      <!-- 1) Logo: centered on xs, left on md+ -->
      <div class="col-12 col-md-4 mb-4 mb-md-0 text-center text-md-start">
        <a href="#">
          <img src="./images/heart3D.png" alt="Get Kinder Heart" height="150">
        </a>
        <p class="mt-2">
          &copy;
          <a href="https://getkindr.com/" target="_blank" rel="noopener noreferrer"
             class="text-body-secondary text-decoration-underline">
            Get Kindr Foundation
          </a>
        </p>
      </div>
      <!-- 2) Social Icons: always centered -->
      <div class="col-12 col-md-4 mb-4 mb-md-0 d-flex justify-content-center">
        <a class="btn btn-floating m-1 text-white" style="background-color: #3b5998;"
           href="https://www.facebook.com/profile.php?id=61576860759313" role="button" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-facebook-f"></i>
        </a>
        <a class="btn btn-floating m-1 text-white" style="background-color: #ac2bac;"
           href="https://www.instagram.com/getkinder/" role="button" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-instagram"></i>
        </a>
        <a class="btn btn-floating m-1 text-white" style="background-color: #0082ca;"
           href="https://www.linkedin.com/company/getkindrfoundation/" role="button" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a class="btn btn-floating m-1 text-white" style="background-color: #c8232c;"
           href="https://ca.pinterest.com/getkindr/" role="button" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-pinterest"></i>
        </a>
      </div>
      <!-- 3) More About: centered on xs, right on md+ -->
      <div class="col-12 col-md-4 mb-4 mb-md-0 text-center text-md-end">
        <h5>More About Get Kinder</h5>
        <ul class="nav flex-column">
          <li class="nav-item mb-2"><a href="/home"        class="nav-link p-0 text-body-secondary">Home</a></li>
          <li class="nav-item mb-2"><a href="about" class="nav-link p-0 text-body-secondary">About</a></li>
          <li class="nav-item mb-2"><a href="contact"     class="nav-link p-0 text-body-secondary">Contact</a></li>
          <li class="nav-item mb-2"><a href="privacy"     class="nav-link p-0 text-body-secondary">Privacy</a></li>
          <li class="nav-item mb-2"><a href="terms"       class="nav-link p-0 text-body-secondary">Terms</a></li>
          <li class="nav-item mb-2"><a href="accessibility" class="nav-link p-0 text-body-secondary">Accessibility</a></li>
        </ul>
      </div>
    </footer>
	  </div>
	</section>

  <script id="org-portal-config" type="application/json"><%- JSON.stringify({
    orgPortalSuspended: orgIsSuspended,
    csrfToken: csrfToken || "",
    userId: user?.id || "",
    orgName: resolvedOrganizationName,
  }).replace(/</g, "\\u003c") %></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script src="/js/bundles/entry.js?<%= assetTag %>"></script>
  <%- include('partials/kai-chat-floating', { greetText: "👋 Hello! I’m KAI, how can I help you make an impact today?" }) %>
  <script>
    const orgPortalConfigNode = document.getElementById("org-portal-config");
    const orgPortalConfig = orgPortalConfigNode ? JSON.parse(orgPortalConfigNode.textContent || "{}") : {};
    const orgPortalSuspended = Boolean(orgPortalConfig.orgPortalSuspended);

    (function () {
      const ratingFill = document.querySelector(".org-hero-rating-stars-fill");
      if (!ratingFill) return;

      const ratingWidth = Number.parseFloat(ratingFill.dataset.ratingWidth || "");
      ratingFill.style.width = `${Number.isFinite(ratingWidth) ? ratingWidth : 0}%`;
    })();

    (function () {
      const fileInput = document.getElementById("org-logo-input");
      const logoImg = document.getElementById("org-hero-logo");
      const clientError = document.getElementById("org-logo-client-error");
      const uploadError = "<%= safeLogoUploadError %>";
      const logoModalEl = document.getElementById("orgLogoModal");
      const logoSaveBtn = logoModalEl
        ? logoModalEl.querySelector('button[name="org_action"][value="save_logo"]')
        : null;

      function showClientError(message) {
        if (!clientError) return;
        clientError.textContent = message;
        clientError.classList.remove("d-none");
      }

      function clearClientError() {
        if (!clientError) return;
        clientError.textContent = "";
        clientError.classList.add("d-none");
      }

      if (uploadError && logoModalEl && window.bootstrap && window.bootstrap.Modal) {
        const logoModal = new window.bootstrap.Modal(logoModalEl);
        logoModal.show();
      }

      if (fileInput && logoImg) {
        fileInput.addEventListener("change", () => {
          clearClientError();
          const file = fileInput.files[0];
          if (!file) return;
          if (file.size > 2 * 1024 * 1024) {
            showClientError("Sorry, that image is too big. Please choose one under 2 MB.");
            fileInput.value = "";
            return;
          }
          if (file.type.startsWith("image/")) {
            const reader = new FileReader();
            reader.onload = (event) => { logoImg.src = event.target.result; };
            reader.readAsDataURL(file);
          } else {
            showClientError("Please choose a valid image file.");
            fileInput.value = "";
          }
        });
      }

      if (logoSaveBtn && fileInput) {
        logoSaveBtn.addEventListener("click", (event) => {
          clearClientError();
          const file = fileInput.files && fileInput.files[0] ? fileInput.files[0] : null;
          if (file) return;
          event.preventDefault();
          showClientError("Choose a logo before saving.");
          fileInput.focus();
        });
      }
    })();

    (function () {
      const orgSwitch = document.getElementById("org-active-switch");
      if (!orgSwitch) return;

      const csrfToken = String(orgPortalConfig.csrfToken || "");
      orgSwitch.addEventListener("change", async () => {
        const nextOrgId = String(orgSwitch.value || "").trim();
        if (!/^\d+$/.test(nextOrgId)) return;
        orgSwitch.disabled = true;
        try {
          const response = await fetch("/api/org/active-org", {
            method: "POST",
            credentials: "include",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-Token": csrfToken,
            },
            body: JSON.stringify({ org_id: Number(nextOrgId) }),
          });
          if (!response.ok) throw new Error("switch_failed");
          window.location.reload();
        } catch (_) {
          orgSwitch.disabled = false;
          window.alert("Could not switch organizations. Please try again.");
        }
      });
    })();

    (function () {
      const requestAdminButton = document.getElementById("org-request-admin-btn");
      const requestAdminModal = document.getElementById("org-admin-request-modal");
      const requestAdminClose = document.getElementById("org-admin-request-close");
      const requestAdminCloseX = document.getElementById("org-admin-request-close-x");
      if (!requestAdminButton || !requestAdminModal || !requestAdminClose || !requestAdminCloseX) return;

      const openModal = () => {
        requestAdminModal.style.display = "flex";
      };
      const closeModal = () => {
        requestAdminModal.style.display = "none";
      };

      requestAdminButton.addEventListener("click", openModal);
      requestAdminClose.addEventListener("click", closeModal);
      requestAdminCloseX.addEventListener("click", closeModal);
      requestAdminModal.addEventListener("click", (event) => {
        if (event.target === requestAdminModal) closeModal();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && requestAdminModal.style.display !== "none") {
          closeModal();
        }
      });
    })();

    if (!orgPortalSuspended) {
      window.renderOrgPortal("#org-portal-root", {
        csrfToken: String(orgPortalConfig.csrfToken || ""),
        userId: String(orgPortalConfig.userId || ""),
        orgName: String(orgPortalConfig.orgName || "")
      });
      window.renderKpiStrip("#org-portal-kpis", {
        csrfToken: String(orgPortalConfig.csrfToken || ""),
      });
    }
  </script>
</body>
</html>
