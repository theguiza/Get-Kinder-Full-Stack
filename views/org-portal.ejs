<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>Organization Portal</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/org-portal.css?<%= assetTag %>" />
  <link rel="icon" href="/images/favicon.png" sizes="32x32" type="image/png" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet" />
</head>
<body class="org-portal-page">
  <%- include("partials/site-header", { currentPage: "org-portal" }) %>

  <div class="org-portal-nav-spacer" aria-hidden="true"></div>

  <%
    const activeOrgStatusValue = String(activeOrgStatus || "").trim().toLowerCase();
    const orgIsSuspended = activeOrgStatusValue === "suspended";
  %>

  <main class="org-portal-main container <%= orgIsSuspended ? 'org-portal-content-ghosted' : '' %>">
    <%
      const fullName = `${user?.firstname || ""} ${user?.lastname || ""}`.trim() || user?.name || "Organization Lead";
      const resolvedOrganizationName =
        (typeof organizationName === "string" && organizationName.trim())
        || user?.organization_name
        || user?.organization
        || user?.org_name
        || "Get Kinder";
      const profilePicture = user?.picture || "/images/nerdy-KAI.png";
      const orgRatingData = (typeof orgRating !== "undefined" && orgRating) ? orgRating : {};
      const orgRatingCount = Number(orgRatingData.count) || 0;
      const orgRatingValue = Number.isFinite(Number(orgRatingData.value))
        ? Number(orgRatingData.value)
        : 5;
      const orgRatingPercent = Math.max(0, Math.min(100, (orgRatingValue / 5) * 100));
      const normalizedActiveOrgId = Number.isInteger(Number(activeOrgId)) ? Number(activeOrgId) : null;
      const membershipOptions = Array.isArray(orgMemberships)
        ? orgMemberships
            .map((entry) => ({
              orgId: Number(entry?.orgId),
              name: String(entry?.name || "").trim(),
            }))
            .filter((entry) => Number.isInteger(entry.orgId) && entry.orgId > 0)
        : [];
      const canSwitchOrganizations = membershipOptions.length > 1;
    %>
    <section class="org-hero mb-3" aria-label="Organization profile hero">
      <div class="org-hero-card">
        <div class="row g-4 align-items-center">
          <div class="col-12 col-md-3 text-center">
            <img
              class="org-hero-avatar rounded-circle"
              width="140"
              height="140"
              alt="Profile photo of <%= fullName %>"
              src="<%= profilePicture %>">
          </div>
          <div class="col-12 col-md-5 text-center text-md-start">
            <div class="org-hero-org"><%= resolvedOrganizationName %></div>
            <h1 class="org-hero-name"><%= fullName %></h1>
            <div class="org-hero-rating-stack">
              <div
                class="org-hero-rating"
                role="img"
                aria-label="Organization rating <%= orgRatingValue.toFixed(1) %> out of 5 stars from <%= orgRatingCount %> ratings"
              >
                <span class="org-hero-rating-stars" aria-hidden="true">
                  <span class="org-hero-rating-stars-base">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                  <span class="org-hero-rating-stars-fill" style="width:<%= orgRatingPercent.toFixed(1) %>%;">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                </span>
                <span class="org-hero-rating-text">
                  <%= `${orgRatingValue.toFixed(1)} (${orgRatingCount})` %>
                </span>
              </div>
              <div class="org-admin-cta-wrap">
                <button type="button" id="org-request-admin-btn" class="btn btn-sm org-btn-ink">
                  Add Admin
                </button>
              </div>
            </div>
            <% if (canSwitchOrganizations) { %>
              <div class="mt-3">
                <label for="org-active-switch" class="form-label mb-1 fw-semibold small text-uppercase text-muted">
                  Active Organization
                </label>
                <select id="org-active-switch" class="form-select form-select-sm">
                  <% membershipOptions.forEach((option) => { %>
                    <option
                      value="<%= option.orgId %>"
                      <%= option.orgId === normalizedActiveOrgId ? "selected" : "" %>
                    >
                      <%= option.name || `Organization #${option.orgId}` %>
                    </option>
                  <% }) %>
                </select>
              </div>
            <% } %>
          </div>
          <div class="col-12 col-md-4">
            <div id="org-portal-kpis"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="org-split-shell mb-4" aria-label="Organization workspace">
      <div id="org-portal-root"></div>
    </section>
  </main>

  <% if (orgIsSuspended) { %>
    <div class="org-suspended-overlay" role="dialog" aria-modal="true" aria-labelledby="org-suspended-title">
      <div class="org-suspended-dialog">
        <h2 id="org-suspended-title">Organization Access Suspended</h2>
        <p class="mb-0">
          You have been suspended please send a message to
          <a href="mailto:kai@getkinder.ai">kai@getkinder.ai</a>
          to request being unsuspended.
        </p>
      </div>
    </div>
  <% } %>

  <div
    id="org-admin-request-modal"
    class="org-admin-request-backdrop"
    role="dialog"
    aria-modal="true"
    aria-labelledby="org-admin-request-title"
    style="display:none;"
  >
    <div class="org-admin-request-card shadow">
      <div class="org-admin-request-header">
        <div class="org-admin-request-title-wrap">
          <span class="org-admin-request-mark" aria-hidden="true">k</span>
          <h5 id="org-admin-request-title" class="mb-0">Add Admin</h5>
        </div>
        <button type="button" id="org-admin-request-close-x" class="org-admin-request-close-x" aria-label="Close">
          &times;
        </button>
      </div>
      <div class="org-admin-request-body">
        To request another admin for your organization send a request to
        <a href="mailto:kai@getkinder.ai">kai@getkinder.ai</a>
      </div>
      <div class="org-admin-request-footer">
        <button type="button" id="org-admin-request-close" class="btn btn-sm org-admin-request-close-btn">
          Close
        </button>
      </div>
    </div>
  </div>

  <section id="footer" class="gradient-background <%= orgIsSuspended ? 'org-portal-content-ghosted' : '' %>">
  <div class="container">
    <footer class="row align-items-center py-5 mt-5 border-top text-body-secondary">
      <!-- 1) Logo: centered on xs, left on md+ -->
      <div class="col-12 col-md-4 mb-4 mb-md-0 text-center text-md-start">
        <a href="#">
          <img src="./images/heart3D.png" alt="Get Kinder Heart" height="150">
        </a>
        <p class="mt-2">
          &copy;
          <a href="https://getkindr.com/" target="_blank" rel="noopener noreferrer"
             class="text-body-secondary text-decoration-underline">
            Get Kindr Foundation
          </a>
        </p>
      </div>
      <!-- 2) Social Icons: always centered -->
      <div class="col-12 col-md-4 mb-4 mb-md-0 d-flex justify-content-center">
        <a class="btn btn-floating m-1 text-white" style="background-color: #3b5998;"
           href="https://www.facebook.com/profile.php?id=61576860759313" role="button" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-facebook-f"></i>
        </a>
        <a class="btn btn-floating m-1 text-white" style="background-color: #ac2bac;"
           href="https://www.instagram.com/getkinder/" role="button" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-instagram"></i>
        </a>
        <a class="btn btn-floating m-1 text-white" style="background-color: #0082ca;"
           href="https://www.linkedin.com/company/getkindrfoundation/" role="button" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a class="btn btn-floating m-1 text-white" style="background-color: #c8232c;"
           href="https://ca.pinterest.com/getkindr/" role="button" target="_blank" rel="noopener noreferrer">
          <i class="fab fa-pinterest"></i>
        </a>
      </div>
      <!-- 3) More About: centered on xs, right on md+ -->
      <div class="col-12 col-md-4 mb-4 mb-md-0 text-center text-md-end">
        <h5>More About Get Kinder</h5>
        <ul class="nav flex-column">
          <li class="nav-item mb-2"><a href="/home"        class="nav-link p-0 text-body-secondary">Home</a></li>
          <li class="nav-item mb-2"><a href="about" class="nav-link p-0 text-body-secondary">About</a></li>
          <li class="nav-item mb-2"><a href="contact"     class="nav-link p-0 text-body-secondary">Contact</a></li>
          <li class="nav-item mb-2"><a href="privacy"     class="nav-link p-0 text-body-secondary">Privacy</a></li>
          <li class="nav-item mb-2"><a href="terms"       class="nav-link p-0 text-body-secondary">Terms</a></li>
          <li class="nav-item mb-2"><a href="accessability" class="nav-link p-0 text-body-secondary">Accessibility</a></li>
        </ul>
      </div>
    </footer>
  </div>
</section>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script src="/js/bundles/entry.js?<%= assetTag %>"></script>
  <script>
    const orgPortalSuspended = <%= orgIsSuspended ? "true" : "false" %>;

    (function () {
      const orgSwitch = document.getElementById("org-active-switch");
      if (!orgSwitch) return;

      const csrfToken = <%- JSON.stringify(csrfToken || "") %>;
      orgSwitch.addEventListener("change", async () => {
        const nextOrgId = String(orgSwitch.value || "").trim();
        if (!/^\d+$/.test(nextOrgId)) return;
        orgSwitch.disabled = true;
        try {
          const response = await fetch("/api/org/active-org", {
            method: "POST",
            credentials: "include",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-Token": csrfToken,
            },
            body: JSON.stringify({ org_id: Number(nextOrgId) }),
          });
          if (!response.ok) throw new Error("switch_failed");
          window.location.reload();
        } catch (_) {
          orgSwitch.disabled = false;
          window.alert("Could not switch organizations. Please try again.");
        }
      });
    })();

    (function () {
      const requestAdminButton = document.getElementById("org-request-admin-btn");
      const requestAdminModal = document.getElementById("org-admin-request-modal");
      const requestAdminClose = document.getElementById("org-admin-request-close");
      const requestAdminCloseX = document.getElementById("org-admin-request-close-x");
      if (!requestAdminButton || !requestAdminModal || !requestAdminClose || !requestAdminCloseX) return;

      const openModal = () => {
        requestAdminModal.style.display = "flex";
      };
      const closeModal = () => {
        requestAdminModal.style.display = "none";
      };

      requestAdminButton.addEventListener("click", openModal);
      requestAdminClose.addEventListener("click", closeModal);
      requestAdminCloseX.addEventListener("click", closeModal);
      requestAdminModal.addEventListener("click", (event) => {
        if (event.target === requestAdminModal) closeModal();
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && requestAdminModal.style.display !== "none") {
          closeModal();
        }
      });
    })();

    if (!orgPortalSuspended) {
      window.renderOrgPortal("#org-portal-root", {
        csrfToken: "<%= csrfToken %>",
        userId: "<%= user.id %>",
        orgName: <%- JSON.stringify(resolvedOrganizationName) %>
      });
      window.renderKpiStrip("#org-portal-kpis", { csrfToken: "<%= csrfToken %>" });
    }
  </script>
</body>
</html>
