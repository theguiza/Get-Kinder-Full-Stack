  <section id="title" class="gradient-background"> <!-- Create a white header using Bootstrap classes. Include an image aligned to the left and a navigation bar aligned to the right with 4 options and a "Sign Up" button. Use 'navbar', 'navbar-light', 'bg-white', 'navbar-expand-lg', and 'd-flex' classes for layout. -->
   <%- include("partials/site-header", { currentPage: "other" }) %>
    <div class="container col-xxl-8 px-4 ">
      <div class="row flex-lg-row-reverse align-items-center g-5 pt-3 mt-1">
        <div class="col-10 col-sm-8 col-lg-6">
          <img src="./images/kai-real.png" class="d-block mx-lg-auto img-fluid" alt="picture of KAI our Kinder AI coach" height="300"
            loading="lazy">
        </div>
        <div class="col-lg-6">
            <h1 class="display-5 fw-bold text-white lh-1 mb-3">Get Kinder Contact</h1>
            <p class="lead text-white mt-1"> We would love to hear from you.</p>
            <p class="lead text-white mt-1">If you have any questions, feedback, or inquiries about our platform, please reach out to us through your preferred method below.</p>
          </section> 
        </div>
      </div>
      </div>
    </div>
  </section>
  <!-- contact form section-->
  <section id="contact">
    <div class="container mt-5"> <!-- make h2 font color: #455a7c-->
      <h2 class="text-center" style="color: #455a7c;">Contact Get Kinder</h2>
      <p class="lead text-center mt-1">We'd love to hear from you. Please fill out the form below and we'll respond as soon as possible.</p>
      <h3 class="mt-4"></h3>
    </div>
  </section>
  <div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6"></div>
            <div class="contact-form">
                <form action="https://formspree.io/f/xldbabay" method="POST">
                    <div class="mb-3">
                        <label for="name" class="form-label">Your Name</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Your Email</label>
                        <input type="email" class="form-control" id="email" name="_replyto" required>
                    </div>
                    <div class="mb-3">
                        <label for="subject" class="form-label">Subject</label>
                        <input type="text" class="form-control" id="subject" name="subject" required>
                    </div>
                    <div class="mb-3">
                        <label for="message" class="form-label">Message</label>
                        <textarea class="form-control" id="message" name="message" rows="5" required></textarea>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">Send Message</button>
                    </div>
                </form>
            </div>

            <p class="text-center mt-4 text-muted">Alternatively, email us at <a href="mailto:hello@getkindr.com">hello@getkindr.com </a></p>
        </div>
    </div>
</div>
  <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Confirm Logout</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="https://www.gravatar.com/avatar/1a5cfe35718514d764a42484a0fb0830?s=64&d=robohashmodal-body">
          Are you sure you want to log out?
        </div>
        <div class="modal-footer">
          <form action="/logout" method="GET">
            <button type="submit" class="btn btn-danger">Log Out</button>
          </form>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        </div>
      </div>
    </div>
  </div>
