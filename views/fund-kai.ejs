  <script>
    window.renderFundKaiThermometer && window.renderFundKaiThermometer("#fund-kai-thermometer-root");
  </script>
  <script>
    const _fkObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          _fkObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fk-fade').forEach(el => _fkObserver.observe(el));
  </script>
