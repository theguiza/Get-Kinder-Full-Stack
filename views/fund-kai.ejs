  <title><%= title %></title>
  <meta name="description" content="Help KAI grow into a fully autonomous volunteer coordination agent for Canadian nonprofits and community organizations.">
  <meta name="author" content="Get Kindr Foundation">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://getkinder.ai/fund-kai">
  <meta property="og:title" content="Help KAI Grow Up — Get Kinder Foundation">
  <meta property="og:description" content="Fund KAI's next stage: a free AI agent that helps nonprofits recruit, match, schedule, verify, and thank volunteers.">
  <meta property="og:url" content="https://getkinder.ai/fund-kai">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://getkinder.ai/images/logo.png">
  <meta property="og:locale" content="en_CA">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Help KAI Grow Up — Get Kinder Foundation">
  <meta name="twitter:description" content="Help KAI grow from a promising teenager into a fully autonomous volunteer coordination agent.">
  <meta name="twitter:image" content="https://getkinder.ai/images/logo.png">

  <link rel="icon" href="/images/favicon.png" sizes="32x32" type="image/png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous">
