  <link rel="canonical" href="https://getkinder.ai/assessment-received" />
  <meta property="og:title" content="Application Received — Get Kinder.ai" />
  <meta property="og:description" content="Your Reporting Readiness Call application has been received by Get Kinder.ai." />
  <meta property="og:url" content="https://getkinder.ai/assessment-received" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://getkinder.ai/images/logo.png" />
  <meta property="og:locale" content="en_CA" />
