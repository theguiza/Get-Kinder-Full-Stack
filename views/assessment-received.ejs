  <meta name="twitter:image" content="https://getkinder.ai/images/logo.png" />

  <link rel="icon" href="/images/favicon.png" sizes="32x32" type="image/png" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />

  <style>
    :root {
      --ar-ink: #455a7c;
      --ar-text: #4d525e;
      --ar-muted: #8f98a8;
      --ar-red: #ff5656;
      --ar-line: #dde2ea;
      --ar-soft: #f8eeee;
      --ar-card: #ffffff;
      --ar-green: #20c997;
    }

    body {
      padding-top: 94px;
      background: var(--ar-soft);
      color: var(--ar-text);
    }

    @media (max-width: 991.98px) {
      body {
        padding-top: 78px;
      }
    }

    .assessment-received {
      min-height: calc(100vh - 94px);
      padding: 0 0 0;
      background: var(--ar-soft);
    }

    .assessment-received__wrap {
      width: min(100%, 660px);
      margin: 0 auto;
      padding: 34px 26px 56px;
    }

    .assessment-received__eyebrow {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
      font-family: "Roboto", sans-serif;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.18em;
      line-height: 1.4;
      text-transform: uppercase;
      color: var(--ar-red);
    }

    .assessment-received__eyebrow::before {
      content: "";
      width: 14px;
      height: 1px;
      background: var(--ar-red);
    }

    .assessment-received__title {
      max-width: 620px;
      margin: 0;
      font-family: "Poppins", sans-serif;
      font-size: clamp(2.25rem, 7vw, 3.25rem);
      font-weight: 700;
      letter-spacing: 0;
      line-height: 1.05;
      color: var(--ar-ink);
    }

    .assessment-received__script {
      font-family: "Lora", Georgia, serif;
      font-style: italic;
      font-weight: 500;
      color: var(--ar-red);
    }

    .assessment-received__intro {
      max-width: 540px;
      margin: 22px 0 34px;
      font-family: "Roboto", sans-serif;
      font-size: 14px;
      line-height: 1.6;
      color: var(--ar-text);
    }

    .assessment-received__card {
      width: 100%;
      margin: 0 0 28px;
      padding: 32px 26px 22px;
      border: 1px solid #d8dde6;
      border-radius: 12px;
      background: var(--ar-card);
    }

    .assessment-received__card-title {
      margin: 0 0 20px 21px;
      font-family: "Roboto", sans-serif;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ar-red);
    }

    .assessment-received__steps {
      display: grid;
      gap: 0;
    }

    .assessment-received__step {
      position: relative;
      display: grid;
      grid-template-columns: 40px minmax(0, 1fr) auto;
      gap: 10px 10px;
      padding: 0 0 24px;
    }

    .assessment-received__step:last-child {
      padding-bottom: 0;
    }

    .assessment-received__step:not(:last-child)::after {
      content: "";
      position: absolute;
      left: 17px;
      top: 37px;
      bottom: 6px;
      width: 1px;
      background: #dfe3ea;
    }

    .assessment-received__icon {
      position: relative;
      z-index: 1;
      width: 35px;
      height: 35px;
      border-radius: 9px;
      display: grid;
      place-items: center;
      background: #f3f6fa;
      border: 1px solid #dce2eb;
      color: var(--ar-ink);
      font-size: 14px;
    }

    .assessment-received__step-kicker {
      margin: 2px 0 4px;
      font-family: "Roboto", sans-serif;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #a6aeba;
    }

    .assessment-received__step-title {
      margin-left: 7px;
      font-family: "Poppins", sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0;
      color: #263653;
      text-transform: none;
    }

    .assessment-received__step-copy {
      max-width: 440px;
      margin: 0;
      font-family: "Roboto", sans-serif;
      font-size: 12px;
      line-height: 1.65;
      color: #465064;
    }

    .assessment-received__badge {
      align-self: start;
      margin-top: 2px;
      border-radius: 999px;
      padding: 4px 8px;
      font-family: "Roboto", sans-serif;
      font-size: 10px;
      font-weight: 700;
      line-height: 1;
      white-space: nowrap;
    }

    .assessment-received__badge--sent {
      background: rgba(32, 201, 151, 0.11);
      color: #10b981;
    }

    .assessment-received__badge--review {
      background: #eef2f6;
      color: #5a6678;
    }

    .assessment-received__badge--next {
      background: #fff1f1;
      color: var(--ar-red);
    }

    .assessment-received__note {
      max-width: 575px;
      margin: 0 0 28px;
      font-family: "Lora", Georgia, serif;
      font-size: 16px;
      font-style: italic;
      line-height: 1.45;
      color: var(--ar-ink);
    }

    .assessment-received__footerline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding-top: 20px;
      border-top: 1px solid #ffd2cd;
    }

    .assessment-received__actions {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .assessment-received__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 36px;
      padding: 8px 18px;
      border: 1px solid #d4dbe5;
      border-radius: 8px;
      background: #fff;
      font-family: "Roboto", sans-serif;
      font-size: 12px;
      font-weight: 700;
      color: #263653;
      text-decoration: none;
    }

    .assessment-received__link {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      min-height: 36px;
      font-family: "Roboto", sans-serif;
      font-size: 12px;
      font-weight: 700;
      color: var(--ar-ink);
      text-decoration: none;
    }

    .assessment-received__cohort {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 28px;
      padding: 5px 10px;
      border: 1px solid #ffc8c2;
      border-radius: 999px;
      background: #fff;
      font-family: "Roboto", sans-serif;
      font-size: 11px;
      font-weight: 700;
      color: #263653;
      white-space: nowrap;
    }

    .assessment-received__dots {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .assessment-received__dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #cfd5dd;
    }

    .assessment-received__dot--active {
      background: var(--ar-red);
    }

    @media (max-width: 640px) {
      .assessment-received__wrap {
        padding: 14px 18px 34px;
      }

      .assessment-received__title {
        font-size: 2.35rem;
      }

      .assessment-received__card {
        padding: 26px 18px 20px;
      }

      .assessment-received__card-title {
        margin-left: 0;
      }

      .assessment-received__step {
        grid-template-columns: 38px minmax(0, 1fr);
      }

      .assessment-received__badge {
        grid-column: 2;
        width: fit-content;
      }

      .assessment-received__footerline {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
