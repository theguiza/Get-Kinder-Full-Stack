  <%- include("partials/site-header", { currentPage: "other" }) %>

  <main class="assessment-received" aria-labelledby="assessment-received-title">
    <div class="assessment-received__wrap">
      <div class="assessment-received__eyebrow">Application received</div>
      <h1 class="assessment-received__title" id="assessment-received-title">
        Thank you &mdash; your application is <span class="assessment-received__script">in.</span>
      </h1>
      <p class="assessment-received__intro">
        We've received your application for a Reporting Readiness Call. A confirmation email is on its way to the address you provided. From here, we review each application carefully and reach out to the nonprofits selected as design partners.
      </p>

      <section class="assessment-received__card" aria-labelledby="assessment-received-next-title">
        <h2 class="assessment-received__card-title" id="assessment-received-next-title">What happens next</h2>

        <div class="assessment-received__steps">
          <article class="assessment-received__step">
            <div class="assessment-received__icon" aria-hidden="true">
              <i class="far fa-envelope"></i>
            </div>
            <div>
              <div class="assessment-received__step-kicker">Step 1 <span class="assessment-received__step-title">Confirmation email</span></div>
              <p class="assessment-received__step-copy">It's on its way to your inbox now. If you don't see it within a few minutes, check your spam or promotions folder.</p>
            </div>
            <span class="assessment-received__badge assessment-received__badge--sent">Sent</span>
          </article>

          <article class="assessment-received__step">
            <div class="assessment-received__icon" aria-hidden="true">
              <i class="far fa-clipboard"></i>
            </div>
            <div>
              <div class="assessment-received__step-kicker">Step 2 <span class="assessment-received__step-title">We review your application</span></div>
              <p class="assessment-received__step-copy">We read every application to understand your reporting needs and confirm whether the assessment is a strong fit for your organization.</p>
            </div>
            <span class="assessment-received__badge assessment-received__badge--review">In review</span>
          </article>

          <article class="assessment-received__step">
            <div class="assessment-received__icon" aria-hidden="true">
              <i class="far fa-calendar-check"></i>
            </div>
            <div>
              <div class="assessment-received__step-kicker">Step 3 <span class="assessment-received__step-title">Selected partners hear back</span></div>
              <p class="assessment-received__step-copy">If selected, you'll receive an email inviting you to schedule your Reporting Readiness Call. The call confirms fit before any materials are reviewed.</p>
            </div>
            <span class="assessment-received__badge assessment-received__badge--next">Next</span>
          </article>
        </div>
      </section>

      <p class="assessment-received__note">
        Thank you for thinking seriously about what your data can prove &mdash; that's exactly the kind of partner this cohort is for.
      </p>

      <div class="assessment-received__footerline">
        <div class="assessment-received__actions">
          <a class="assessment-received__button" href="/home/how-it-works">See how it works</a>
          <a class="assessment-received__link" href="/home"><i class="fas fa-arrow-left" aria-hidden="true"></i> Return to home</a>
        </div>
        <div class="assessment-received__cohort" aria-label="Cohort 1 has 5 design partner slots">
          <span class="assessment-received__dots" aria-hidden="true">
            <span class="assessment-received__dot"></span>
            <span class="assessment-received__dot"></span>
            <span class="assessment-received__dot assessment-received__dot--active"></span>
            <span class="assessment-received__dot assessment-received__dot--active"></span>
            <span class="assessment-received__dot assessment-received__dot--active"></span>
          </span>
          Cohort 01 &middot; 5 design partner slots
        </div>
      </div>
    </div>
  </main>

  <%- include("partials/site-footer") %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js" integrity="sha384-k6d4wzSIapyDyv1kpU366/PK5hCdSbCRGRCMv+eplOQJWyd1fbcAu9OCUj5zNLiq" crossorigin="anonymous"></script>
</body>
</html>
