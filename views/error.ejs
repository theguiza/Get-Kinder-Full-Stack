    <div class="container mt-5"> <!-- make h2 font color: #455a7c-->

<main class="error-page">
      <img src="./images/frustrated-KAI.png" class="d-block mx-lg-auto img-fluid" alt="picture of KAI our Kinder AI coach" height="250" loading="lazy">
  <h1 style="color: #ff5656; font-size: 3rem; margin-top: 2rem;">Oops! 500 server error (database or server issue)</h1>
  <p style="color: #455a7c; font-size: 1.5rem; margin-top: 1rem;">Houston we have a problem! Click the button below to return to kindness!</p>
  <a href="/home" class="btn btn-primary btn-lg">Go Back Home</a>
