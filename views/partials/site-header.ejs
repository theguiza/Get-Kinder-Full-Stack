<%
  const cp = typeof currentPage === "string" ? currentPage : "other";
  const homeHref = "/home";
  const currentUser = (typeof user !== "undefined" && user) ? user : null;

  const futureModuleItems = [
    { key: "events", label: "Volunteering", href: "/events" },
    { key: "donor", label: "Donors", href: "/donor" }
  ];

  const visibleFutureModuleItems = futureModuleItems.filter((item) => !(item.authOnly && !currentUser));
  const headerAvatarSrc = (typeof resolveUserPictureUrl === "function")
    ? resolveUserPictureUrl(currentUser)
    : (currentUser?.picture || "/images/nerdy-KAI.png");

  const isFutureModulePage = visibleFutureModuleItems.some((item) => cp === item.key);
  const showHomeNav = cp === "donate" || isFutureModulePage;

  const donateHref = "/donate";
  const donateLabel = "DONATE";
  const showDonateCta = cp !== "donate";
%>
<header>
  <nav class="navbar fixed-top navbar-light bg-white navbar-expand-lg">
    <div class="container-fluid d-flex">
      <a class="navbar-brand" href="<%= homeHref %>"><img src="/images/logo.png" alt="Get Kinder logo" class="logo-img" height="80"></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#siteHeaderNav" aria-controls="siteHeaderNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
      <div class="collapse navbar-collapse" id="siteHeaderNav">
        <ul class="navbar-nav flex-lg-grow-1 justify-content-lg-center align-items-lg-center">
          <% if (showHomeNav) { %>
            <li class="nav-item">
              <a
                class="nav-link mx-1 font-hover"
                href="<%= homeHref %>"
                style="font-size: 1.1rem; color: #455a7c; padding-right: 20px;"
              >Home</a>
            </li>
          <% } %>
          <li class="nav-item dropdown">
            <button
              class="nav-link dropdown-toggle mx-1 font-hover<%= isFutureModulePage ? " active" : "" %>"
              type="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
              <%- isFutureModulePage ? 'aria-current="page"' : "" %>
              style="font-size: 1.1rem; color: #455a7c; padding-right: 20px;"
            >Future modules</button>
            <ul class="dropdown-menu">
              <% visibleFutureModuleItems.forEach((item) => { %>
                <li>
                  <a
                    class="dropdown-item<%= cp === item.key ? " active" : "" %>"
                    href="<%= item.href %>"
                    <%- cp === item.key ? 'aria-current="page"' : "" %>
                  ><%= item.label %></a>
                </li>
              <% }) %>
            </ul>
          </li>
          <% if (showDonateCta) { %>
            <li class="nav-item">
              <a class="btn btn-primary btn-lg" href="<%= donateHref %>" style="font-size: 1.2rem; color:aliceblue; background-color: #ff5656; border-color: #ff5656;"><%= donateLabel %></a>
            </li>
          <% } %>
        </ul>
        <ul class="navbar-nav d-flex align-items-lg-center mt-3 mt-lg-0">
          <% if (currentUser) { %>
            <li class="nav-item d-flex align-items-center me-3">
              <a href="/profile" class="d-flex align-items-center text-decoration-none me-3 font-hover" aria-label="View profile" style="color: #455a7c;">
                <span class="fw-bold me-2" style="font-size: 1.1rem; color: inherit;"><%= currentUser.firstname || currentUser.email %></span>
                <img src="<%= headerAvatarSrc %>" class="rounded-circle" width="32" height="32" alt="Get Kinder User Avatar">
              </a>
              <form action="/logout" method="GET" class="d-inline m-0">
                <button type="submit" class="btn btn-outline-danger btn-sm">Log Out</button>
              </form>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="btn btn-primary btn-lg" style="font-size: 1.2rem; color: white; text-decoration: none; width: 100%; min-width: 120px; text-align: center;" href="/login" role="button">Log In</a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
</header>
