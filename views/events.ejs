  <!-- Alerts -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show auto-dismiss" role="alert">
      Registration successful! Welcome to Get Kinder 🌟
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  <% if (typeof loginSuccess !== 'undefined' && loginSuccess && typeof name !== 'undefined' && name) { %>
    <div class="alert alert-success alert-dismissible fade show auto-dismiss" role="alert">
      Welcome back, <%= name %>! 🎉
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  <% if (typeof req !== 'undefined' && req.query && req.query.cancelled === '1') { %>
    <div class="alert alert-info alert-dismissible fade show auto-dismiss" role="alert">
      Challenge cancelled successfully. You can start a new one anytime!
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  <!-- Header -->
   <%- include("partials/site-header", { currentPage: "events" }) %>
  <!-- Main container -->
  <div class="dashboard-container">
    <section class="events-hero">
      <div class="container">
        <div class="row align-items-center g-4">
          <div class="col-12 col-md-6">
            <h1 class="events-hero-title">
              Volunteer opportunities<br>
              near <span class="events-hero-location">
                Vancouver and Victoria BC
              </span>
              <button
                type="button"
                class="events-hero-location-change"
                data-bs-toggle="modal"
                data-bs-target="#cityChangeModal"
              >
                <i class="fas fa-map-marker-alt"></i> change
              </button>
            </h1>
            <p class="events-hero-sub">
              Every hour you give earns impact credits that you can turn into rewards,
              or pay them forward to fund the causes you care about most.
            </p>
          </div>
          <div class="col-12 col-md-6">
            <div class="events-hero-photo-wrap">
              <img
                src="/images/events-hero.jpg"
                alt="Community volunteers working together"
                class="events-hero-photo"
                onerror="this.parentElement.style.display='none'"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="events-chip-bar">
      <%
        const eventsPagePagination = (props && props.pagination) || {};
        const eventsPageView = eventsPagePagination.view === 'archive' ? 'archive' : 'upcoming';
        const eventsPageCauseTagRaw = typeof eventsPagePagination.cause_tag === 'string'
          ? eventsPagePagination.cause_tag.trim()
          : '';
        const eventsPageCauseTag = eventsPageCauseTagRaw.toLowerCase();
        const eventsPageCommunityTag = typeof eventsPagePagination.community_tag === 'string'
          ? eventsPagePagination.community_tag.trim()
          : '';
        const eventsPageLimitNum = Number(eventsPagePagination.limit);
        const eventsPageLimit = Number.isFinite(eventsPageLimitNum)
          ? Math.min(Math.max(eventsPageLimitNum, 1), 50)
          : 20;
        const eventsPageCursor = eventsPagePagination.cursor && typeof eventsPagePagination.cursor === 'object'
          ? eventsPagePagination.cursor
          : null;
        const eventsPageFilters = {
          view: eventsPageView,
          cause_tag: eventsPageCauseTagRaw || null,
          community_tag: eventsPageCommunityTag || null,
          limit: eventsPageLimit,
          cursor: eventsPageCursor
        };
      %>
      <div class="container">
        <div class="events-chip-row" id="events-chip-row">
          <button class="events-chip <%= !eventsPageCauseTag ? 'active' : '' %>" data-cause="">
            🌟 All
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'outdoors' ? 'active' : '' %>" data-cause="outdoors">
            🌿 Outdoors
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'food' ? 'active' : '' %>" data-cause="food">
            🍎 Food & Hunger
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'education' ? 'active' : '' %>" data-cause="education">
            📚 Education
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'community' ? 'active' : '' %>" data-cause="community">
            🏘 Community
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'health' ? 'active' : '' %>" data-cause="health">
            💊 Health
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'arts' ? 'active' : '' %>" data-cause="arts">
            🎨 Arts & Culture
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'sports' ? 'active' : '' %>" data-cause="sports">
            🏅 Sports
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'animals' ? 'active' : '' %>" data-cause="animals">
            🐾 Animals
          </button>
          <button class="events-chip <%= eventsPageCauseTag === 'environment' ? 'active' : '' %>" data-cause="environment">
            ♻️ Environment
          </button>
        </div>
      </div>
    </section>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const chips = document.querySelectorAll('.events-chip');

        chips.forEach(function (chip) {
          chip.addEventListener('click', function () {
            chips.forEach(function (c) { c.classList.remove('active'); });
            chip.classList.add('active');

            const cause = chip.getAttribute('data-cause');
            try {
              const url = new URL(window.location.href);
              if (cause) {
                url.searchParams.set('cause_tag', cause);
              } else {
                url.searchParams.delete('cause_tag');
              }
              // Reset keyset cursor when changing filters.
              url.searchParams.delete('after_start_at');
              url.searchParams.delete('after_id');
              url.searchParams.delete('before_start_at');
              url.searchParams.delete('before_id');

              const current = window.location.pathname + window.location.search + window.location.hash;
              const next = url.pathname + url.search + (url.hash || '');
              if (next !== current) {
                window.history.replaceState({}, '', next);
              }
            } catch (_) {
              // Keep client-side filter behavior if URL mutation fails.
            }

            window.dispatchEvent(new CustomEvent('getkinder:causeFilter', {
              detail: { causeTag: cause }
            }));
          });
        });
      });
    </script>

    <%
      const currentView = eventsPageView;
      const currentLimitNum = Number(eventsPagePagination.limit);
      const currentLimit = Number.isFinite(currentLimitNum) ? Math.min(Math.max(currentLimitNum, 1), 50) : 20;
      const currentCommunityTag = eventsPageCommunityTag;
      const currentCauseTag = eventsPageCauseTagRaw;
      const nextCursor = eventsPagePagination.nextCursor && typeof eventsPagePagination.nextCursor === 'object'
        ? eventsPagePagination.nextCursor
        : null;

      function buildEventsHref(overrides) {
        const params = {
          limit: currentLimit,
          view: currentView === 'archive' ? 'archive' : null,
          community_tag: currentCommunityTag || null,
          cause_tag: currentCauseTag || null,
          after_start_at: null,
          after_id: null,
          before_start_at: null,
          before_id: null,
          ...(overrides || {}),
        };
        const pairs = Object.entries(params)
          .filter(([, value]) => value !== null && value !== undefined && value !== '')
          .map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`);
        return pairs.length ? `/events?${pairs.join('&')}` : '/events';
      }

      const upcomingHref = buildEventsHref({
        view: null,
        after_start_at: null,
        after_id: null,
        before_start_at: null,
        before_id: null,
      });
      const archiveHref = buildEventsHref({
        view: 'archive',
        after_start_at: null,
        after_id: null,
        before_start_at: null,
        before_id: null,
      });

      let loadMoreHref = null;
      if (nextCursor) {
        if (currentView === 'archive' && nextCursor.before_id) {
          loadMoreHref = buildEventsHref({
            view: 'archive',
            before_start_at: nextCursor.before_start_at || null,
            before_id: nextCursor.before_id || null,
          });
        } else if (currentView === 'upcoming' && nextCursor.after_id) {
          loadMoreHref = buildEventsHref({
            view: null,
            after_start_at: nextCursor.after_start_at || null,
            after_id: nextCursor.after_id || null,
          });
        }
      }
    %>

    <section class="container mt-3">
      <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <div class="btn-group" role="group" aria-label="Events view toggle">
          <a
            href="<%= upcomingHref %>"
            class="btn btn-sm <%= currentView === 'upcoming' ? 'btn-primary' : 'btn-outline-primary' %>"
          >Upcoming</a>
          <a
            href="<%= archiveHref %>"
            class="btn btn-sm <%= currentView === 'archive' ? 'btn-primary' : 'btn-outline-primary' %>"
          >Archive</a>
        </div>
        <small class="text-muted">
          <%= currentView === 'archive' ? 'Showing past events' : 'Showing upcoming and ongoing events' %>
        </small>
      </div>
    </section>

    <style>
      .events-ssr-shell {
        display: grid;
        gap: 24px;
      }
      .events-ssr-detail,
      .events-ssr-card,
      .events-ssr-empty {
        border: 1px solid #d6deeb;
        border-radius: 20px;
        background: #fff;
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.08);
      }
      .events-ssr-detail {
        padding: 24px;
      }
      .events-ssr-detail-eyebrow,
